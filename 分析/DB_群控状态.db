DATA_BLOCK "DB_群控状态"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   VAR 
      外呼上已登记 : Array[1..9] of Bool;
      外呼下已登记 : Array[2..10] of Bool;
      外呼上分配给梯号 : Array[1..9] of Int;
      外呼下分配给梯号 : Array[2..10] of Int;
      梯当前楼层 : Array[1..3] of Int;
      梯运行方向 : Array[1..3] of Int;
      梯是否服务中 : Array[1..3] of Bool;
      梯是否故障 : Array[1..3] of Bool;
      梯是否满载 : Array[1..3] of Bool;
      群控扫描计数器 : Int;
      外呼上等待周期 : Array[1..9] of Int;
       外呼下等待周期 : Array[2..10] of Int;
       梯是否检修 : Array[1..3] of Bool;
       检修原始信号 : Array[1..3] of Bool;
       检修信号已见低电平 : Array[1..3] of Bool;
       检修有效信号 : Array[1..3] of Bool;
       检修启动高电平忽略 : Array[1..3] of Bool;
       全局初始化请求 : Bool;
       自动运行上次 : Bool;
       自动运行上升沿 : Bool;
       自动运行下降沿 : Bool;
       自动运行当前 : Bool;
       自动运行上升沿计数 : DInt;
       自动运行下降沿计数 : DInt;
       自动运行高电平扫描数 : DInt;
       自动运行低电平扫描数 : DInt;
       自动运行最近高电平扫描数 : DInt;
       自动运行最大高电平扫描数 : DInt;
       初始化诊断目标楼层有效 : Bool;
       初始化诊断可启动 : Array[1..3] of Bool;
       初始化诊断检修信号 : Array[1..3] of Bool;
       初始化诊断门锁闭合 : Array[1..3] of Bool;
       初始化诊断准备就绪 : Array[1..3] of Bool;
       初始化诊断自动运行信号 : Array[1..3] of Bool;
       初始化诊断上行接触器 : Array[1..3] of Bool;
       初始化诊断下行接触器 : Array[1..3] of Bool;
       初始化诊断当前楼层 : Array[1..3] of Int;
       智能帧有效 : Bool;
       智能调度允许 : Bool;
       Python心跳超时 : Bool;
       智能降级 : Bool;
       智能错误代码 : Int;
       Python心跳 : Word;
       Python心跳上次 : Word;
       Python帧序号 : Word;
       Python预测序号 : Word;
       Python可用度 : Int;
       Python主场景 : Int;
       智能需求上 : Array[1..9] of Int;
       智能需求下 : Array[2..10] of Int;
       智能权重等待 : Int;
       智能权重距离 : Int;
       智能权重反向 : Int;
       智能权重启停 : Int;
       智能权重预测 : Int;
     END_VAR


BEGIN

END_DATA_BLOCK

