
// ===== OB1 主循环 =====

// --- 段1：输入映射 ---
"FC_输入映射"();

// --- 段2：Modbus数据采集 ---
"caiji"();

// --- 段3：Modbus TCP服务器 ---
"tcp"();

// --- 段4：单梯控制循环 ---
FOR #梯号 := 1 TO "DB_系统配置".电梯总数 DO
    CASE #梯号 OF
        1:
            "单梯控制_DB_1号梯"(电梯 := "DB_全部电梯".梯数组[1]);
        2:
            "单梯控制_DB_2号梯"(电梯 := "DB_全部电梯".梯数组[2]);
        3:
            "单梯控制_DB_3号梯"(电梯 := "DB_全部电梯".梯数组[3]);
    END_CASE;
END_FOR;

// --- 段5：群控调度 ---
"群控调度_DB"();

// --- 段6：电机启动信号汇总 ---
FOR #梯号 := 1 TO "DB_系统配置".电梯总数 DO
    "DB_全部电梯".梯数组[#梯号].电机启动信号
    := "DB_全部电梯".梯数组[#梯号].上行接触器
    OR "DB_全部电梯".梯数组[#梯号].下行接触器;
END_FOR;

// --- 段7：输出映射 ---
"FC_输出映射"();