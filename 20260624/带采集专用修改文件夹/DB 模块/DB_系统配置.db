DATA_BLOCK "DB_系统配置"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   VAR 
      建筑最低楼层 : Int;   // 物理最低楼层号（通常为 1）
      建筑最高楼层 : Int;   // 物理最高楼层号（最终目标 10 层）
      建筑最低楼层减一 : Int;   // = 最低楼层 - 1，用于初始化时楼层校准下限
      建筑最高楼层加一 : Int;   // = 最高楼层 + 1，用于初始化时楼层校准上限
      电梯总数 : Int;   // 投入运行的电梯数量（最终目标 3 部）
      目标初始化楼层 : Int;   // 初始化完成后电梯停靠的楼层
      初始化方向选择 : Bool;   // TRUE=先向上寻顶再下行到目标；FALSE=先向下寻底再上行到目标
      手动初始化触发 : Bool;   // 手动触发初始化按钮的上升沿信号
      开门保持时间 : Time;   // 开门到位后保持的时间（自动关门触发延时）
      光幕重开门等待时间 : Time;   // 光幕信号消失后重新尝试关门的延时
      超重阈值_kg : Real;   // 超过此值：禁止关门、禁止起动、蜂鸣报警
      满载阈值_kg : Real;   // 超过此值：点亮满载灯、不接受厅外呼梯
      有人检测阈值_kg : Real;   // 超过此值：认为轿厢有人，开启照明/风扇
      称重模拟量最大值 : Real;   // 模拟量输入模块的量程上限（对应最大载重）
      照明延时关断 : Time;   // 无人无需求后，照明延时关断（TOF 模式）
      风扇延时关断 : Time;   // 无人无需求后，风扇延时关断（TOF 模式）
      端站停车延时 : Time;   // 初始化时顶端/底端停车时间
      平层信号滤波时间 : Time;   // 平层信号持续多久才算有效（防抖动）
      群控调度策略 : Int;   // 0=关闭群控;1=传统就近调度;2=PLC内部智能评分调度
      群控允许节能待机 : Bool;   // 无任务时是否允许部分电梯停止运行
      群控外呼超时重分配_s : Int;   // 外呼分配给某梯后，超过此秒数未响应则重新分配
      智能权重距离 : Int;   // 策略2：楼层距离代价权重
      智能权重等待 : Int;   // 策略2：长等待奖励权重
      智能权重反向 : Int;   // 策略2：反向运行惩罚权重
      智能权重启停 : Int;   // 策略2：空闲梯启动惩罚权重
      智能权重需求 : Int;   // 策略2：本层需求强度奖励权重
      智能权重均衡 : Int;   // 策略2：本轮重复分配惩罚权重
      智能长等待阈值_s : Int;   // 策略2：超过该等待秒数后加强优先级
      智能长等待奖励 : Int;   // 策略2：长等待呼叫的固定奖励
      低速到停车过渡延时 : Time;
      高速切低速过渡延时 : Time;
      自动运行记忆 : Bool;
      自动运行触发 : Bool;
      自动运行锁存 : Bool;
      梯满载阈值 : Array[1..3] of Real;
      梯超重阈值 : Array[1..3] of Real;
   END_VAR


BEGIN
   建筑最低楼层 := 1;
   建筑最高楼层 := 10;
   建筑最低楼层减一 := 0;
   建筑最高楼层加一 := 11;
   电梯总数 := 3;
   目标初始化楼层 := 5;
   开门保持时间 := t#3s;
   光幕重开门等待时间 := t#3s;
   超重阈值_kg := 1100.0;
   满载阈值_kg := 1000.0;
   有人检测阈值_kg := 5.0;
   称重模拟量最大值 := 27648.0;
   照明延时关断 := T#10s;
   风扇延时关断 := T#20s;
   端站停车延时 := T#2s;
   平层信号滤波时间 := T#10ms;
   群控调度策略 := 2;
   群控外呼超时重分配_s := 20;
   智能权重距离 := 100;
   智能权重等待 := 8;
   智能权重反向 := 60;
   智能权重启停 := 30;
   智能权重需求 := 20;
   智能权重均衡 := 80;
   智能长等待阈值_s := 15;
   智能长等待奖励 := 100;
   低速到停车过渡延时 := T#200ms;
   高速切低速过渡延时 := T#200ms;
   自动运行记忆 := FALSE;
   自动运行触发 := FALSE;
   自动运行锁存 := FALSE;
   梯满载阈值[1] := 560.0;
   梯满载阈值[2] := 560.0;
   梯满载阈值[3] := 800.0;
   梯超重阈值[1] := 700.0;
   梯超重阈值[2] := 700.0;
   梯超重阈值[3] := 1000.0;

END_DATA_BLOCK

