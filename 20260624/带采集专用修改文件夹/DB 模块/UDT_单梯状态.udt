      上端站第二限位 : Bool;
      下端站第一限位 : Bool;
      下端站第二限位 : Bool;
      开门继电器 : Bool;
      关门继电器 : Bool;
      开门到位 : Bool;
      关门到位 : Bool;
      轿厢门锁信号 : Bool;
      楼层门锁信号 : Array[1..10] of Bool;
      光幕信号 : Bool;
      开门按钮 : Bool;
      关门按钮 : Bool;
      载重模拟量原始值 : Int;
