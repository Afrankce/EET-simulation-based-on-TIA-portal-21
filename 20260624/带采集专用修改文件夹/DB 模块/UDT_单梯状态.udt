TYPE "UDT_单梯状态"
VERSION : 0.1
   STRUCT
      梯号 : Int;
      当前楼层 : Int;
      上行接触器 : Bool;
      下行接触器 : Bool;
      高速接触器 : Bool;
      低速接触器 : Bool;
      一级减速制动 : Bool;
      二级减速制动 : Bool;
      三级减速制动 : Bool;
      电机启动信号 : Bool;
      上平层信号 : Bool;
      下平层信号 : Bool;
